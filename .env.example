# Required for live episode data (ISR revalidates every hour)
RSS_FEED_URL=

# Listen section links
APPLE_PODCASTS_URL=
SPOTIFY_URL=
YOUTUBE_URL=

# Social
LINKEDIN_URL=https://www.linkedin.com/company/theexchangenpod

# Deploy to Vercel:
# 1. Push this repo to GitHub
# 2. Import the project at vercel.com/new
# 3. Add the environment variables above in Project Settings
# 4. Point theexchange.studio DNS to Vercel (A record 76.76.21.21 or CNAME cname.vercel-dns.com)
# 5. Waitlist submissions are stored in /tmp on Vercel (ephemeral). Replace the API route with your CRM or email provider for production.
