# YouTube channel feed (default episode source, ISR hourly)
YOUTUBE_URL=https://www.youtube.com/@TheExchange.Studio
RSS_FEED_URL=https://www.youtube.com/feeds/videos.xml?channel_id=UCTrA61Wc5aZtorudu_2JRaw

# Optional podcast platforms
APPLE_PODCASTS_URL=
SPOTIFY_URL=

# Social
LINKEDIN_URL=https://www.linkedin.com/company/theexchangenpod

# Deploy to Vercel:
# 1. Push this repo to GitHub
# 2. Import the project at vercel.com/new
# 3. Add the environment variables above in Project Settings
# 4. Point theexchange.studio DNS to Vercel
# 5. Waitlist submissions are stored in /tmp on Vercel (ephemeral). Replace the API route with your CRM or email provider for production.
